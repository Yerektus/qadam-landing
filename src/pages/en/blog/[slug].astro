---
import Layout from "@/layouts/main.astro"
import { getBlogPosts, type BlogPost } from "@/lib/blog-posts"
import { m } from "@/paraglide/messages.js"
import { localizeHref } from "@/paraglide/runtime.js"

export function getStaticPaths() {
  return getBlogPosts("en").map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }))
}

type Props = {
  post: BlogPost
}

const { post } = Astro.props
const lang = Astro.url.pathname.startsWith("/en") ? "en" : "ru"
---

<Layout title={`${post.title} | QADAM`}>
  <main class="pt-12">
    <article class="w-full">
      <div class="m-auto max-w-3xl px-8 py-12 lg:px-0 lg:py-20">
        <a
          href={localizeHref("/blog", { locale: lang })}
          class="mb-12 inline-flex text-sm text-muted-foreground transition hover:text-foreground"
        >
          &larr; {m.blog_back_to_blog({}, { locale: lang })}
        </a>

        <header>
          <p class="text-md font-normal">{post.date}</p>
          <h1
            class="sm:text3xl mt-4 text-2xl font-normal text-black lg:text-4xl"
          >
            {post.title}
          </h1>
          <p class="sm:text-md mt-4 text-sm text-muted-foreground">
            {post.author}{m.blog_author_separator({}, { locale: lang })}{
              post.role
            }
          </p>
        </header>

        <p
          class="mt-8 text-xl leading-relaxed font-light text-black sm:text-xl"
        >
          {post.lead}
        </p>

        <div class="mt-8 space-y-16">
          {
            post.sections.map((section) => (
              <section>
                <h2 class="text-2xl font-normal text-black">{section.title}</h2>

                <div class="mt-8 space-y-8 text-xl font-light text-neutral-700">
                  {section.paragraphs.map((paragraph) => (
                    <p set:html={paragraph} />
                  ))}
                </div>

                {section.items && (
                  <ul class="mt-8 space-y-4 text-xl leading-relaxed font-light text-neutral-700">
                    {section.items.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                )}
              </section>
            ))
          }
        </div>
      </div>
    </article>
  </main>
</Layout>
