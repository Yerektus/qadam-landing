---
import { buttonVariants } from "../../ui/button"
import { Image } from "astro:assets"
import { getLangFromUrl, getUi } from "@/i18n/utils"

const lang = getLangFromUrl(Astro.url)
const { hero } = getUi(lang).landing
---

<section
  class="grid grid-cols-1 px-6 py-20 sm:px-10 lg:h-screen lg:grid-cols-2 lg:items-center lg:px-[72px] lg:py-0"
>
  <div class="flex w-full flex-col items-center justify-center lg:items-start">
    <div class="mb-7 max-w-[760px] pt-10 text-center lg:mb-9 lg:text-left">
      <h1
        class="mb-2 text-2xl text-balance sm:text-3xl md:text-4xl lg:mb-6 lg:text-5xl"
      >
        {hero.title}
      </h1>
      <p
        class="max-w-xl text-lg font-medium text-muted-foreground sm:text-xs md:text-xl"
      >
        {hero.subtitle}
      </p>
    </div>
    <div>
      <a
        href="#contact"
        class={buttonVariants({ size: "lg", class: "px-8 py-5" })}
      >
        {hero.cta}
      </a>
    </div>
  </div>

  <div
    class="mt-12 flex w-full items-center justify-center lg:mt-0 lg:justify-end"
  >
    <div
      class="aspect-square w-full max-w-[460px] overflow-visible sm:max-w-[540px] lg:max-w-[640px] xl:max-w-[700px]"
    >
      <Image
        src="/hero.png"
        class="h-full w-full object-contain lg:translate-x-4 xl:translate-x-8"
        alt={hero.imageAlt}
        width={1200}
        height={900}
        format="webp"
      />
    </div>
  </div>
</section>
